    <!-- ══════════════════════════════════════════
         RESULTS SECTION
         Controller'dan Model gelince burası dolar.
         foreach örneği aşağıda yorum olarak var.
    ══════════════════════════════════════════ -->
    <section id="results-section" style="@(Model != null && Model.Any() ? "display:block;" : "display:none;")padding:60px 0;background:var(--dark-2);">
        <div class="container">
            <div class="d-flex align-items-end justify-content-between mb-5">
                <div>
                    <div class="section-label">Arama Sonuçları</div>
                    <h2 class="section-heading">Bulunan <span>Oteller</span></h2>
                    <p class="section-sub" id="results-count"></p>
                </div>
            </div>

            <div id="loadingOverlay" style="display:none;text-align:center;padding:60px 0;">
                <div class="lux-spinner"></div>
                <p style="color:var(--muted);letter-spacing:2px;font-size:0.82rem;">OTELLER YÜKLENIYOR…</p>
            </div>
            <div class="row g-4" id="hotelResults">
                @if (Model != null && Model.Any())
                {
                    @foreach (var hotel in Model)
                    {
                        <div class="col-lg-4 col-md-6">
                            <div class="hotel-card">
                                <div class="hotel-img-wrap">
                                    <img src="@(hotel.PhotoUrls?.FirstOrDefault() ?? "")" alt="@hotel.Name" loading="lazy" />
                                    <span class="hotel-badge-img">Otel</span>
                                </div>
                                <div class="hotel-body">
                                    <div class="hotel-name">@hotel.Name</div>
                                    <!-- YENİ -->
                                    <div class="hotel-location">
                                        <i class="fas fa-map-marker-alt" style="color:var(--gold);font-size:0.7rem;"></i>
                                        @GetCountryName(hotel.CountryCode)
                                    </div>
                                    <!-- Yıldız -->
                                    @if (hotel.PropertyClass.HasValue && hotel.PropertyClass > 0)
                                    {
                                        <div style="color:var(--gold); font-size:0.78rem; margin-bottom:8px;">
                                            @(new string('★', hotel.PropertyClass.Value))
                                        </div>
                                    }

                                    <!-- Fiyat -->
                                    @if (hotel.PriceBreakdown?.GrossPrice != null)
                                    {
                                        <div style="font-family:'Cormorant Garamond',serif; font-size:1.1rem; color:var(--gold); margin-bottom:12px;">
                                            @hotel.PriceBreakdown.GrossPrice.Value.ToString("N0")
                                            <span style="font-size:0.72rem; color:var(--muted); font-family:'DM Sans',sans-serif;">
                                                @hotel.PriceBreakdown.GrossPrice.Currency / gece
                                            </span>
                                        </div>
                                    }

                                    <div class="d-flex align-items-center justify-content-between mt-2">
                                        <div>
                                            <div class="hotel-rating">
                                                <i class="fas fa-star" style="font-size:0.7rem;"></i>
                                                @hotel.ReviewScore?.ToString("0.0")
                                            </div>
                                            @if (hotel.ReviewCount.HasValue)
                                            {
                                                <div style="font-size:0.72rem; color:var(--muted); margin-top:3px;">
                                                    @hotel.ReviewCount yorum
                                                </div>
                                            }
                                        </div>
                                        <a href="/Hotel/Detail/@hotel.HotelId" class="btn-detail">
                                            Detay <i class="fas fa-arrow-right" style="font-size:0.7rem;"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
            <div class="row g-4" id="hotelResults"></div>
        </div>
    </section>



@model List<RapidApi_BookingProject.Dtos.HotelPropertyDto>
@{
    Layout = null;
    ViewData["Title"] = "StayLux - Premium Hotel Booking";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>StayLux — Lüks Otel Rezervasyonu</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style>
        :root {
            --gold: #C9A84C;
            --gold-light: #E8C96A;
            --gold-dark: #9A7A2E;
            --dark: #0D0D0D;
            --dark-2: #141414;
            --dark-3: #1E1E1E;
            --light: #F5F0E8;
            --muted: #888;
            --white: #FFFFFF;
            --radius: 16px;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background: var(--dark);
            color: var(--light);
            font-family: 'DM Sans',sans-serif;
            font-weight: 300;
            overflow-x: hidden;
        }

        h1, h2, h3, h4 {
            font-family: 'Cormorant Garamond',serif;
            font-weight: 500;
        }

        /* NAVBAR */
        .navbar-staylux {
            background: rgba(13,13,13,0.92);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(201,168,76,0.15);
            padding: 18px 0;
            position: sticky;
            top: 0;
            z-index: 1000;
            transition: all 0.3s;
        }

        .navbar-brand-logo {
            font-family: 'Cormorant Garamond',serif;
            font-size: 1.9rem;
            font-weight: 600;
            color: var(--gold) !important;
            letter-spacing: 2px;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .logo-icon {
            width: 36px;
            height: 36px;
            background: linear-gradient(135deg,var(--gold),var(--gold-dark));
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .navbar-staylux .nav-link {
            color: rgba(245,240,232,0.75) !important;
            font-size: 0.88rem;
            letter-spacing: 1.2px;
            text-transform: uppercase;
            font-weight: 400;
            padding: 8px 16px !important;
            transition: color 0.2s;
        }

            .navbar-staylux .nav-link:hover {
                color: var(--gold) !important;
            }

        .btn-nav-cta {
            background: linear-gradient(135deg,var(--gold),var(--gold-dark));
            color: var(--dark) !important;
            font-weight: 600 !important;
            border-radius: 50px;
            padding: 8px 24px !important;
            font-size: 0.82rem !important;
            letter-spacing: 1px;
        }

        /* HERO */
        .hero-section {
            min-height: 100vh;
            position: relative;
            display: flex;
            align-items: center;
            overflow: hidden;
        }

        .hero-bg {
            position: absolute;
            inset: 0;
            background-image: url('https://images.unsplash.com/photo-1566073771259-6a8506099945?w=1920&q=80');
            background-size: cover;
            background-position: center;
            filter: brightness(0.35);
            transform: scale(1.05);
            animation: heroZoom 20s ease-in-out infinite alternate;
        }

        @@keyframes heroZoom {
            from {
                transform: scale(1.05);
            }

            to {
                transform: scale(1.12);
            }
        }

        .hero-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(160deg,rgba(13,13,13,0.6) 0%,rgba(13,13,13,0.2) 40%,rgba(201,168,76,0.08) 100%);
        }

        .hero-content {
            position: relative;
            z-index: 2;
            padding: 80px 0 60px;
        }

        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(201,168,76,0.15);
            border: 1px solid rgba(201,168,76,0.3);
            color: var(--gold-light);
            padding: 6px 18px;
            border-radius: 50px;
            font-size: 0.78rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 28px;
            animation: fadeInUp 0.8s ease both;
        }

        .hero-title {
            font-size: clamp(2.8rem,6vw,5.5rem);
            line-height: 1.05;
            color: var(--white);
            margin-bottom: 20px;
            animation: fadeInUp 0.9s 0.1s ease both;
        }

            .hero-title span {
                color: var(--gold);
            }

        .hero-subtitle {
            color: rgba(245,240,232,0.65);
            font-size: 1.05rem;
            max-width: 500px;
            margin-bottom: 48px;
            line-height: 1.7;
            animation: fadeInUp 1s 0.2s ease both;
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* FORM */
        .search-card {
            background: rgba(20,20,20,0.92);
            backdrop-filter: blur(30px);
            border: 1px solid rgba(201,168,76,0.2);
            border-radius: 24px;
            padding: 36px 40px;
            box-shadow: 0 40px 80px rgba(0,0,0,0.6);
            animation: fadeInUp 1.1s 0.3s ease both;
        }

        .form-label-lux {
            color: var(--gold);
            font-size: 0.72rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            font-weight: 500;
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .form-control-lux, .form-select-lux {
            background: rgba(255,255,255,0.04) !important;
            border: 1px solid rgba(201,168,76,0.2) !important;
            color: var(--light) !important;
            border-radius: 12px !important;
            padding: 12px 16px !important;
            font-family: 'DM Sans',sans-serif;
            font-size: 0.92rem;
            transition: all 0.3s;
        }

            .form-control-lux:focus, .form-select-lux:focus {
                background: rgba(201,168,76,0.06) !important;
                border-color: rgba(201,168,76,0.6) !important;
                box-shadow: 0 0 0 3px rgba(201,168,76,0.12) !important;
                outline: none;
            }

            .form-control-lux::placeholder {
                color: rgba(245,240,232,0.3) !important;
            }

            .form-select-lux option {
                background: #1a1a1a;
                color: var(--light);
            }

            .form-select-lux:disabled {
                opacity: 0.4;
            }

        .btn-search-lux {
            background: linear-gradient(135deg,var(--gold) 0%,var(--gold-dark) 100%);
            color: var(--dark);
            border: none;
            border-radius: 14px;
            padding: 14px 36px;
            font-weight: 600;
            font-size: 0.92rem;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            width: 100%;
            cursor: pointer;
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
        }

            .btn-search-lux:hover {
                transform: translateY(-2px);
                box-shadow: 0 12px 30px rgba(201,168,76,0.4);
            }

            .btn-search-lux .btn-shine {
                position: absolute;
                top: 0;
                left: -100%;
                width: 60%;
                height: 100%;
                background: linear-gradient(90deg,transparent,rgba(255,255,255,0.25),transparent);
                transition: left 0.5s;
            }

            .btn-search-lux:hover .btn-shine {
                left: 150%;
            }

        .divider-gold {
            height: 1px;
            background: linear-gradient(90deg,transparent,rgba(201,168,76,0.3),transparent);
            margin: 28px 0;
        }

        /* RESULTS */
        #results-section {
            display: block;
            padding: 60px 0;
            background: var(--dark-2);
        }

        .section-heading {
            font-size: 2.5rem;
            color: var(--white);
            margin-bottom: 8px;
        }

            .section-heading span {
                color: var(--gold);
            }

        .section-sub {
            color: var(--muted);
            font-size: 0.9rem;
            letter-spacing: 1px;
        }

        /* HOTEL CARD */
        .hotel-card {
            background: var(--dark-3);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: var(--radius);
            overflow: hidden;
            transition: all 0.4s cubic-bezier(0.25,0.46,0.45,0.94);
            height: 100%;
        }

            .hotel-card:hover {
                transform: translateY(-8px);
                border-color: rgba(201,168,76,0.3);
                box-shadow: 0 24px 50px rgba(0,0,0,0.5);
            }

        .hotel-img-wrap {
            position: relative;
            overflow: hidden;
            height: 200px;
        }

            .hotel-img-wrap img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform 0.5s ease;
            }

        .hotel-card:hover .hotel-img-wrap img {
            transform: scale(1.08);
        }

        .hotel-badge-img {
            position: absolute;
            top: 12px;
            left: 12px;
            background: rgba(13,13,13,0.85);
            backdrop-filter: blur(8px);
            color: var(--gold);
            font-size: 0.72rem;
            padding: 4px 10px;
            border-radius: 50px;
            border: 1px solid rgba(201,168,76,0.3);
            letter-spacing: 1px;
        }

        .hotel-body {
            padding: 20px;
        }

        .hotel-name {
            font-family: 'Cormorant Garamond',serif;
            font-size: 1.3rem;
            color: var(--white);
            margin-bottom: 6px;
            font-weight: 600;
        }

        .hotel-location {
            color: var(--muted);
            font-size: 0.82rem;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .hotel-rating {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: rgba(201,168,76,0.1);
            color: var(--gold);
            font-size: 0.82rem;
            font-weight: 600;
            padding: 4px 12px;
            border-radius: 50px;
        }

        .btn-detail {
            background: transparent;
            border: 1px solid rgba(201,168,76,0.4);
            color: var(--gold);
            border-radius: 10px;
            padding: 8px 20px;
            font-size: 0.82rem;
            letter-spacing: 1px;
            transition: all 0.3s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

            .btn-detail:hover {
                background: var(--gold);
                color: var(--dark);
                border-color: var(--gold);
            }

        /* SPINNER */
        .lux-spinner {
            width: 50px;
            height: 50px;
            border: 2px solid rgba(201,168,76,0.2);
            border-top-color: var(--gold);
            border-radius: 50%;
            animation: spin 0.9s linear infinite;
            margin: 0 auto 16px;
        }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        /* WIDGETS */
        .widgets-section {
            padding: 60px 0;
            background: var(--dark-2);
        }

        .widget-card {
            background: var(--dark-3);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: var(--radius);
            padding: 28px;
            height: 100%;
            position: relative;
            overflow: hidden;
        }

            .widget-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 2px;
                background: linear-gradient(90deg,var(--gold-dark),var(--gold),var(--gold-dark));
            }

        .widget-title {
            font-size: 0.72rem;
            letter-spacing: 2.5px;
            text-transform: uppercase;
            color: var(--gold);
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .currency-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

            .currency-item:last-child {
                border-bottom: none;
            }

        .currency-flag {
            font-size: 1.4rem;
            margin-right: 8px;
        }

        .currency-code {
            font-weight: 600;
            color: var(--white);
            font-size: 0.92rem;
        }

        .currency-rate {
            font-size: 1.05rem;
            font-weight: 600;
            color: var(--gold-light);
        }

        .converter-row {
            display: grid;
            grid-template-columns: 1fr auto 1fr;
            gap: 12px;
            align-items: end;
        }

        .swap-btn {
            background: rgba(201,168,76,0.15);
            border: 1px solid rgba(201,168,76,0.3);
            color: var(--gold);
            width: 42px;
            height: 42px;
            border-radius: 50%;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
        }

            .swap-btn:hover {
                background: var(--gold);
                color: var(--dark);
            }

        .weather-days {
            display: flex;
            gap: 8px;
            overflow-x: auto;
            padding-bottom: 4px;
        }

        .weather-day {
            flex: 0 0 auto;
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.07);
            border-radius: 12px;
            padding: 12px 10px;
            text-align: center;
            min-width: 72px;
            transition: all 0.3s;
        }

            .weather-day:hover, .weather-day.active {
                background: rgba(201,168,76,0.1);
                border-color: rgba(201,168,76,0.3);
            }

            .weather-day .day-name {
                font-size: 0.72rem;
                color: var(--muted);
                margin-bottom: 6px;
            }

            .weather-day .day-emoji {
                font-size: 1.6rem;
                margin-bottom: 6px;
            }

            .weather-day .day-temp {
                font-size: 0.85rem;
                color: var(--light);
                font-weight: 500;
            }

        .crypto-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

            .crypto-item:last-child {
                border-bottom: none;
            }

        .crypto-icon {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            margin-right: 10px;
        }

        .crypto-price {
            font-weight: 600;
            color: var(--white);
        }

        .crypto-name {
            font-size: 0.82rem;
            color: var(--muted);
        }

        /* DESTINATIONS */
        .destinations-section {
            padding: 80px 0;
        }

        .dest-card {
            position: relative;
            border-radius: var(--radius);
            overflow: hidden;
            cursor: pointer;
            transition: transform 0.4s ease;
        }

            .dest-card:hover {
                transform: translateY(-6px);
            }

            .dest-card img {
                width: 100%;
                height: 280px;
                object-fit: cover;
                transition: transform 0.5s ease;
            }

            .dest-card:hover img {
                transform: scale(1.08);
            }

        .dest-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to top,rgba(0,0,0,0.8) 0%,transparent 60%);
        }

        .dest-info {
            position: absolute;
            bottom: 20px;
            left: 20px;
            right: 20px;
        }

        .dest-name {
            font-family: 'Cormorant Garamond',serif;
            font-size: 1.5rem;
            font-weight: 600;
            color: var(--white);
        }

        .dest-count {
            color: var(--gold-light);
            font-size: 0.8rem;
            letter-spacing: 1px;
        }

        /* SECTION LABEL */
        .section-label {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: var(--gold);
            font-size: 0.72rem;
            letter-spacing: 3px;
            text-transform: uppercase;
            margin-bottom: 16px;
        }

            .section-label::before, .section-label::after {
                content: '';
                width: 30px;
                height: 1px;
                background: var(--gold);
                opacity: 0.5;
            }

        /* FOOTER */
        .footer-section {
            background: var(--dark-2);
            border-top: 1px solid rgba(201,168,76,0.12);
            padding: 60px 0 30px;
        }

        .footer-brand {
            font-family: 'Cormorant Garamond',serif;
            font-size: 1.8rem;
            color: var(--gold);
            font-weight: 600;
        }

        .footer-desc {
            color: rgba(245,240,232,0.45);
            font-size: 0.88rem;
            line-height: 1.7;
            max-width: 280px;
        }

        .footer-title {
            color: var(--gold);
            font-size: 0.72rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 20px;
        }

        .footer-link {
            display: block;
            color: rgba(245,240,232,0.5);
            text-decoration: none;
            font-size: 0.88rem;
            margin-bottom: 10px;
            transition: color 0.2s;
        }

            .footer-link:hover {
                color: var(--gold);
            }

        .footer-social {
            display: flex;
            gap: 12px;
            margin-top: 20px;
        }

        .social-btn {
            width: 38px;
            height: 38px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--muted);
            text-decoration: none;
            transition: all 0.3s;
            font-size: 0.9rem;
        }

            .social-btn:hover {
                background: rgba(201,168,76,0.15);
                border-color: rgba(201,168,76,0.4);
                color: var(--gold);
            }

        .footer-bottom {
            margin-top: 40px;
            padding-top: 24px;
            border-top: 1px solid rgba(255,255,255,0.06);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 12px;
        }

        .footer-copy {
            color: rgba(245,240,232,0.3);
            font-size: 0.8rem;
        }

        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }

        ::-webkit-scrollbar-track {
            background: var(--dark);
        }

        ::-webkit-scrollbar-thumb {
            background: var(--gold-dark);
            border-radius: 3px;
        }

        @@media(max-width:768px) {
            .search-card {
                padding: 24px 20px;
            }

            .hero-title {
                font-size: 2.6rem;
            }

            .converter-row {
                grid-template-columns: 1fr;
            }

            .swap-btn {
                margin: 0 auto;
            }
        }
    </style>
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar-staylux">
        <div class="container">
            <div class="d-flex align-items-center justify-content-between w-100">
                <a href="/" class="navbar-brand-logo">
                    <div class="logo-icon"><i class="fas fa-gem text-dark" style="font-size:0.9rem;"></i></div>
                    StayLux
                </a>
                <ul class="nav d-none d-lg-flex align-items-center gap-1">
                    <li><a href="/Hotel/Index" class="nav-link">Keşfet</a></li>
                    <li><a href="/Hotel/Search/" class="nav-link">Destinasyonlar</a></li>
                    <li><a href="/AI/Index/" class="nav-link">Tur Oluştur</a></li>
                    <li><a href="/About/Index/" class="nav-link">Hakkımızda</a></li>
                    <li><a href="#" class="nav-link btn-nav-cta ms-2">Giriş Yap</a></li>
                </ul>
                <button class="btn d-lg-none" style="color:var(--gold);font-size:1.3rem;"><i class="fas fa-bars"></i></button>
            </div>
        </div>
    </nav>

    <!-- HERO + SEARCH FORM -->
    <section class="hero-section">
        <div class="hero-bg"></div>
        <div class="hero-overlay"></div>
        <div class="container hero-content">
            <div class="row align-items-center g-5">

                <!-- Sol -->
                <div class="col-lg-5">
                    <div class="hero-badge"><i class="fas fa-star" style="font-size:0.6rem;"></i> Dünyanın En İyi Otelleri</div>
                    <h1 class="hero-title">Hayalindeki<br><span>Konaklamayı</span><br>Bul</h1>
                    <p class="hero-subtitle">Dünya genelinde 2 milyondan fazla otel arasından seyahatinize en uygun seçeneği kolayca bulun.</p>
                    <div class="d-flex gap-4">
                        <div><div style="font-size:1.5rem;font-weight:700;color:var(--gold);font-family:'Cormorant Garamond',serif;">2M+</div><div style="font-size:0.75rem;color:var(--muted);letter-spacing:1px;">Otel Seçeneği</div></div>
                        <div style="width:1px;background:rgba(255,255,255,0.1);"></div>
                        <div><div style="font-size:1.5rem;font-weight:700;color:var(--gold);font-family:'Cormorant Garamond',serif;">150+</div><div style="font-size:0.75rem;color:var(--muted);letter-spacing:1px;">Ülke</div></div>
                        <div style="width:1px;background:rgba(255,255,255,0.1);"></div>
                        <div><div style="font-size:1.5rem;font-weight:700;color:var(--gold);font-family:'Cormorant Garamond',serif;">4.9</div><div style="font-size:0.75rem;color:var(--muted);letter-spacing:1px;">Ortalama Puan</div></div>
                    </div>
                </div>

                <!-- Sağ: Form -->
                <div class="col-lg-7">
                    <div class="search-card">
                        <div class="d-flex align-items-center justify-content-between mb-4">
                            <h2 style="font-size:1.6rem;color:var(--white);">Otel Ara</h2>
                            <span style="font-size:0.75rem;color:var(--muted);letter-spacing:1px;">RapidAPI Powered</span>
                        </div>

                        <form id="searchForm" asp-action="Search" asp-controller="Hotel" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" id="destIdInput" name="DestId" />

                            <div class="row g-3">
                                <!-- Ülke -->
                                <div class="col-md-6">
                                    <label class="form-label-lux"><i class="fas fa-globe-europe" style="font-size:0.65rem;"></i> Ülke</label>
                                    <select class="form-select-lux form-select" id="countrySelect" name="Country" required onchange="loadCities(this.value)">

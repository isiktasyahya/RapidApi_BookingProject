    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
    <script>
        async function convertCurrency() {
            const amount = document.getElementById('convAmount').value;
            const from = document.getElementById('convFrom').value;
            const to = document.getElementById('convTo').value;

            const res = await fetch(`/Hotel/Convert?from=${from}&to=${to}&amount=${amount}`);
            const data = await res.json();

            document.getElementById('convResult').style.display = 'block';
            document.getElementById('convResultValue').textContent = data.result + ' ' + to;
            document.getElementById('convResultLabel').textContent = amount + ' ' + from + ' = ' + data.result + ' ' + to;
        }

        const cityData = {
            France: ['Paris', 'Lyon', 'Marseille', 'Nice', 'Bordeaux', 'Toulouse', 'Strasbourg', 'Cannes', 'Nantes', 'Montpellier'],
            Italy: ['Rome', 'Milan', 'Venice', 'Florence', 'Naples', 'Turin', 'Bologna', 'Palermo', 'Verona', 'Genoa'],
            Spain: ['Madrid', 'Barcelona', 'Seville', 'Valencia', 'Malaga', 'Granada', 'Bilbao', 'Ibiza', 'Mallorca', 'Tenerife'],
            Greece: ['Athens', 'Santorini', 'Mykonos', 'Rhodes', 'Thessaloniki', 'Corfu', 'Zakynthos', 'Heraklion', 'Chania', 'Naxos'],
            Germany: ['Berlin', 'Munich', 'Hamburg', 'Frankfurt', 'Cologne', 'Stuttgart', 'Dresden', 'Nuremberg', 'Leipzig', 'Heidelberg'],
            Netherlands: ['Amsterdam', 'Rotterdam', 'The Hague', 'Utrecht', 'Eindhoven', 'Groningen', 'Maastricht', 'Haarlem', 'Delft', 'Leiden'],
            Portugal: ['Lisbon', 'Porto', 'Algarve', 'Sintra', 'Cascais', 'Faro', 'Lagos', 'Coimbra', 'Braga', 'Evora'],
            Austria: ['Vienna', 'Salzburg', 'Innsbruck', 'Graz', 'Linz', 'Hallstatt', 'Klagenfurt', 'Baden', 'Zell am See', 'Bregenz'],
            Switzerland: ['Zurich', 'Geneva', 'Bern', 'Lucerne', 'Basel', 'Interlaken', 'Zermatt', 'Lausanne', 'St. Gallen', 'Lugano'],
            Croatia: ['Zagreb', 'Dubrovnik', 'Split', 'Hvar', 'Zadar', 'Pula', 'Rijeka', 'Rovinj', 'Trogir', 'Korcula'],
        };

        function loadCities(country) {
            const citySelect = document.getElementById('citySelect');
            const cityStatus = document.getElementById('cityStatus');
            const destIdInput = document.getElementById('destIdInput');

            citySelect.innerHTML = '<option value="">— Şehir Seçin —</option>';
            destIdInput.value = '';
            cityStatus.textContent = '';

            if (!country) { citySelect.disabled = true; return; }

            const cities = cityData[country] || [];
            cities.forEach(city => {
                const opt = document.createElement('option');
                opt.value = city;
                opt.textContent = city;
                citySelect.appendChild(opt);
            });
            citySelect.disabled = false;
        }

        document.getElementById('citySelect').addEventListener('change', function () {
            document.getElementById('destIdInput').value = this.value;
        });

        document.getElementById('searchForm').addEventListener('submit', function (e) {
            const city = document.getElementById('citySelect').value;
            const checkIn = document.getElementById('checkIn').value;
            const checkOut = document.getElementById('checkOut').value;

            if (!city) {
                e.preventDefault();
                document.getElementById('cityStatus').innerHTML =
                    '<span style="color:#f87171;font-size:0.72rem;">⚠ Lütfen bir şehir seçin</span>';
                return;
            }
            if (checkIn >= checkOut) {
                e.preventDefault();
                alert('Çıkış tarihi, giriş tarihinden sonra olmalıdır.');
            }
        });

        window.addEventListener('DOMContentLoaded', () => {
            const today = new Date();
            const tomorrow = new Date(today); tomorrow.setDate(today.getDate() + 1);
            const nextWeek = new Date(today); nextWeek.setDate(today.getDate() + 7);
            const fmt = d => d.toISOString().split('T')[0];
            document.getElementById('checkIn').value = fmt(tomorrow);
            document.getElementById('checkOut').value = fmt(nextWeek);
            document.getElementById('checkIn').min = fmt(today);
        });

        window.addEventListener('scroll', () => {
            const nav = document.querySelector('.navbar-staylux');
            nav.style.padding = window.scrollY > 50 ? '12px 0' : '18px 0';
        });

        function quickSearch(city) {
            document.querySelector('.hero-section').scrollIntoView({ behavior: 'smooth' });
        }

        async function fetchCurrencyRates() { /* TODO */ }
        async function fetchWeather() {
            const city = document.getElementById('weatherCity').value;
            if (!city) return;

            const res = await fetch(`/Hotel/Weather?city=${city}`);
            const data = await res.json();

            // Ana hava durumu
            const condition = data.current_observation.condition;
            const location = data.location;

            document.getElementById('weatherMain').style.display = 'block';
            document.getElementById('weatherMainTemp').textContent = condition.temperature + '°F';
            document.getElementById('weatherMainDesc').textContent = condition.text;
            document.getElementById('weatherCityName').textContent = location.city + ', ' + location.country;
            document.getElementById('weatherMainEmoji').textContent = getWeatherEmoji(condition.code);

            // Tahmin günleri
            const forecasts = data.forecasts.slice(0, 4);
            const daysEl = document.getElementById('weatherDays');
            daysEl.innerHTML = '';

            forecasts.forEach(f => {
                daysEl.innerHTML += `
            <div class="weather-day">
                <div class="day-name">${f.day}</div>
                <div class="day-emoji">${getWeatherEmoji(f.code)}</div>
                <div class="day-temp">${f.low}° / ${f.high}°</div>
            </div>
        `;
            });
        }

        function getWeatherEmoji(code) {
            if (code <= 4) return '⛈️';
            if (code <= 8) return '🌨️';
            if (code <= 12) return '🌧️';
            if (code <= 18) return '🌦️';
            if (code <= 24) return '🌬️';
            if (code <= 28) return '☁️';
            if (code <= 30) return '⛅';
            if (code == 32 || code == 34 || code == 36) return '☀️';
            if (code <= 40) return '🌧️';
            if (code <= 46) return '🌨️';
            if (code <= 47) return '⛈️';
            return '🌡️';
        }
        async function fetchCrypto() {
            const res = await fetch('/Hotel/GetCrypto');
            const data = await res.json();
            const coins = data.data.coins;

            coins.forEach(coin => {
                const priceEl = document.getElementById(`${coin.symbol.toLowerCase()}-price`);
                if (priceEl) {
                    const price = parseFloat(coin.price).toLocaleString('tr-TR', { maximumFractionDigits: 2 });
                    const change = parseFloat(coin.change);
                    const color = change >= 0 ? '#4ade80' : '#f87171';
                    const arrow = change >= 0 ? '▲' : '▼';
                    priceEl.innerHTML = `$${price} <span style="color:${color}; font-size:0.75rem;">${arrow} ${Math.abs(change)}%</span>`;
                }
            });
        }

        // Sayfa açılınca otomatik çek
        window.addEventListener('DOMContentLoaded', () => {
            fetchCrypto();
        });

        function swapCurrencies() {
            const f = document.getElementById('convFrom');
            const t = document.getElementById('convTo');
            [f.value, t.value] = [t.value, f.value];
        }

    </script>
    @functions {
        string GetCountryName(string code)
        {
            return code?.ToUpper() switch
            {
                "FR" => "Fransa",
                "IT" => "İtalya",
                "ES" => "İspanya",
                "GR" => "Yunanistan",
                "DE" => "Almanya",
                "NL" => "Hollanda",
                "PT" => "Portekiz",
                "AT" => "Avusturya",
                "CH" => "İsviçre",
                "HR" => "Hırvatistan",
                _ => code ?? "—"
            };
        }
    }
</body>
